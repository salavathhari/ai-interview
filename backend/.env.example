# ── API Keys ──
OPENAI_API_KEY=sk-your-key-here

# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/ai_platform

# ── Authentication ──
JWT_SECRET_KEY=generate-a-strong-random-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
JWT_REFRESH_EXPIRE_DAYS=7

# ── Field-Level Encryption (AES-256-GCM) ──
# CRITICAL: Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`
# All existing encrypted data becomes undecryptable if this changes.
FIELD_ENCRYPTION_KEY=

# ── Redis ──
REDIS_HOST=localhost
REDIS_PASSWORD=changeme

# ── Environment ──
ENVIRONMENT=development
